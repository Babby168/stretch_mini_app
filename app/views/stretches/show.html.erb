<div class="max-w-4xl mx-auto px-4 py-8">
  <!-- 戻るボタン -->
  <%= link_to stretches_path(target_area: params[:target_area]), class: "inline-flex items-center text-blue-600 hover:text-blue-800 mb-6 transition-colors" do %>
    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
    </svg>
    一覧に戻る
  <% end %>

  <!-- メインコンテンツ -->

  <div class="bg-white rounded-lg shadow-lg overflow-hidden pb-8">
    <!-- サムネイルエリア -->
    
    <div class="relative bg-gray-200 rounded-lg mb-4 overflow-hidden" style="height: 300px;">
      <% if @stretch.image_path.present? %>
        <%= image_tag @stretch.image_path,
            alt: @stretch.name,
            class: "w-full h-64 md:h-75 object-cover" %>
      <% end %>

    <!-- カウントダウン表示（画像の上に重ねる） -->
      <div class="absolute inset-0 flex items-center justify-center">
        <p class="text-6xl font-bold text-white bg-black bg-opacity-50 px-8 py-4 rounded-lg" id="timer-display" data-stretch-id="<%= @stretch.id %>">
          01:00
        </p>
      </div>
    </div>

    <!-- ボタンエリア -->
    <div class="flex gap-4 justify-center mb-4">
      <button id="start-btn" class="bg-blue-500 text-white px-8 py-3 rounded-lg hover:bg-blue-600 text-lg font-bold">
        スタート
      </button>
      <button id="stop-btn" class="bg-red-500 text-white px-8 py-3 rounded-lg hover:bg-red-600 text-lg font-bold" style="display: none;">
        終了する
      </button>
    </div>

    <!-- 完了メッセージ（最初は非表示） -->
    <div id="completion-message" class="hidden mt-6 text-center">
      <p class="text-3xl font-bold text-green-600">完了！🎉</p>
    </div>

    <!-- 隠しフィールドでストレッチIDを保持 -->
    <input type="hidden" id="stretch-id" value="<%= @stretch.id%>">

    
    <!-- タイトルエリア -->

    <div class="mb-6">
      <h1 class="text-3xl font-bold text-gray-800 mb-3">
        <%= @stretch.name %>
      </h1>

      <span class="inline-block bg-blue-500 text-white text-sm px-4 py-2 rounded-full">
        <%= @stretch.target_area %>
      </span>
    </div>
    
    
    <!-- 説明エリア -->

    <div class="mb-8">
      <h2 class="text-xl font-semibold text-gray-800 mb-3">説明</h2>
      <p class="text-gray-700 leading-relaxed whitespace-pre-wrap">
        <%= @stretch.description %>
      </p>
    </div>


    <!-- 手順エリア -->
    <% if @stretch.steps.present? %>
      <div class="mb-8">
        <h2 class="text-xl font-semibold text-gray-800 mb-3">手順</h2>
        <div class="bg-gray-50 rounded-lg p-6">
          <% @stretch.steps.split("\n").each_with_index do |step, index| %>
            <p class="text-gray-700 leading-relaxed mb-2">
              <%= step.strip %>
            </p>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- 所要時間エリア -->
      <div class="flex items-center text-gray-600">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span>所要時間: １分</span>
      </div>
  </div>
</div>

<%= javascript_import_module_tag "timer" %>
